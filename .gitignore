# ===== Backend: Java / Maven =====
backend/target/
**/*.class

# Imágenes subidas en runtime (galería de productos): no versionar el contenido,
# pero mantener el directorio para que la app encuentre ./uploads en un clone fresco.
backend/uploads/*
!backend/uploads/.gitkeep

# ===== Frontend: Node (a futuro) =====
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.env
frontend/.env.*

# ===== IDE / Editores =====
.idea/
*.iml
.vscode/
*.swp
*.swo

# ===== Sistema operativo =====
.DS_Store
Thumbs.db

# ===== Claude Code (config local de cada máquina) =====
.claude/settings.local.json

# ===== Logs =====
*.log
