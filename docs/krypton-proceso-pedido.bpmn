<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Krypton"
                  targetNamespace="http://krypton.com/bpmn">

  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_Krypton" name="Krypton E-commerce — Proceso de pedido" processRef="Process_Pedido" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Pedido" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Cliente" name="Cliente">
        <bpmn:flowNodeRef>start1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>s1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>g1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Admin" name="Administrador">
        <bpmn:flowNodeRef>g2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>t5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>s2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end3</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- Carril Cliente -->
    <bpmn:startEvent id="start1" name="Cliente decide comprar">
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="t1" name="Agrega productos al carrito">
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="t2" name="Inicia checkout y elige comprobante (boleta/factura)">
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:outgoing>f3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="s1" name="Calcula envío e IGV (gratis ≥ S/300)">
      <bpmn:incoming>f3</bpmn:incoming>
      <bpmn:outgoing>f4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="g1" name="¿Confirma y paga?">
      <bpmn:incoming>f4</bpmn:incoming>
      <bpmn:outgoing>f5</bpmn:outgoing>
      <bpmn:outgoing>f6</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="t3" name="Paga el pedido">
      <bpmn:incoming>f5</bpmn:incoming>
      <bpmn:outgoing>f7</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="end1" name="Compra abandonada">
      <bpmn:incoming>f6</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Carril Administrador -->
    <bpmn:exclusiveGateway id="g2" name="¿Se cancela el pedido?">
      <bpmn:incoming>f7</bpmn:incoming>
      <bpmn:outgoing>f8</bpmn:outgoing>
      <bpmn:outgoing>f11</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="t4" name="Prepara y despacha el pedido (Enviado)">
      <bpmn:incoming>f8</bpmn:incoming>
      <bpmn:outgoing>f9</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="t5" name="Confirma la entrega (Entregado)">
      <bpmn:incoming>f9</bpmn:incoming>
      <bpmn:outgoing>f10</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="end2" name="Pedido entregado">
      <bpmn:incoming>f10</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="s2" name="Repone el stock (movimiento de entrada)">
      <bpmn:incoming>f11</bpmn:incoming>
      <bpmn:outgoing>f12</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="end3" name="Pedido cancelado">
      <bpmn:incoming>f12</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Flujos -->
    <bpmn:sequenceFlow id="f1" sourceRef="start1" targetRef="t1" />
    <bpmn:sequenceFlow id="f2" sourceRef="t1" targetRef="t2" />
    <bpmn:sequenceFlow id="f3" sourceRef="t2" targetRef="s1" />
    <bpmn:sequenceFlow id="f4" sourceRef="s1" targetRef="g1" />
    <bpmn:sequenceFlow id="f5" name="Sí, paga" sourceRef="g1" targetRef="t3" />
    <bpmn:sequenceFlow id="f6" name="No, abandona" sourceRef="g1" targetRef="end1" />
    <bpmn:sequenceFlow id="f7" name="Pedido confirmado" sourceRef="t3" targetRef="g2" />
    <bpmn:sequenceFlow id="f8" name="No" sourceRef="g2" targetRef="t4" />
    <bpmn:sequenceFlow id="f9" sourceRef="t4" targetRef="t5" />
    <bpmn:sequenceFlow id="f10" sourceRef="t5" targetRef="end2" />
    <bpmn:sequenceFlow id="f11" name="Sí, cancela" sourceRef="g2" targetRef="s2" />
    <bpmn:sequenceFlow id="f12" sourceRef="s2" targetRef="end3" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <bpmndi:BPMNShape id="Participant_Krypton_di" bpmnElement="Participant_Krypton" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1480" height="460" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Cliente_di" bpmnElement="Lane_Cliente" isHorizontal="true">
        <dc:Bounds x="190" y="80" width="1450" height="210" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Admin_di" bpmnElement="Lane_Admin" isHorizontal="true">
        <dc:Bounds x="190" y="290" width="1450" height="250" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="start1_di" bpmnElement="start1">
        <dc:Bounds x="232" y="167" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t1_di" bpmnElement="t1">
        <dc:Bounds x="310" y="145" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t2_di" bpmnElement="t2">
        <dc:Bounds x="480" y="145" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s1_di" bpmnElement="s1">
        <dc:Bounds x="660" y="145" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="g1_di" bpmnElement="g1" isMarkerVisible="true">
        <dc:Bounds x="830" y="160" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t3_di" bpmnElement="t3">
        <dc:Bounds x="930" y="145" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end1_di" bpmnElement="end1">
        <dc:Bounds x="837" y="240" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="g2_di" bpmnElement="g2" isMarkerVisible="true">
        <dc:Bounds x="965" y="355" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t4_di" bpmnElement="t4">
        <dc:Bounds x="1070" y="340" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="t5_di" bpmnElement="t5">
        <dc:Bounds x="1250" y="340" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end2_di" bpmnElement="end2">
        <dc:Bounds x="1420" y="362" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="s2_di" bpmnElement="s2">
        <dc:Bounds x="925" y="455" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end3_di" bpmnElement="end3">
        <dc:Bounds x="1140" y="472" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="f1_di" bpmnElement="f1">
        <di:waypoint x="268" y="185" /><di:waypoint x="310" y="185" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f2_di" bpmnElement="f2">
        <di:waypoint x="430" y="185" /><di:waypoint x="480" y="185" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f3_di" bpmnElement="f3">
        <di:waypoint x="610" y="185" /><di:waypoint x="660" y="185" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f4_di" bpmnElement="f4">
        <di:waypoint x="780" y="185" /><di:waypoint x="830" y="185" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f5_di" bpmnElement="f5">
        <di:waypoint x="880" y="185" /><di:waypoint x="930" y="185" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f6_di" bpmnElement="f6">
        <di:waypoint x="855" y="210" /><di:waypoint x="855" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f7_di" bpmnElement="f7">
        <di:waypoint x="990" y="225" /><di:waypoint x="990" y="355" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f8_di" bpmnElement="f8">
        <di:waypoint x="1015" y="380" /><di:waypoint x="1070" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f9_di" bpmnElement="f9">
        <di:waypoint x="1200" y="380" /><di:waypoint x="1250" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f10_di" bpmnElement="f10">
        <di:waypoint x="1370" y="380" /><di:waypoint x="1420" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f11_di" bpmnElement="f11">
        <di:waypoint x="990" y="405" /><di:waypoint x="990" y="455" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f12_di" bpmnElement="f12">
        <di:waypoint x="1055" y="490" /><di:waypoint x="1140" y="490" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
