{
  "info": {
    "name": "Krypton E-commerce — Auth",
    "description": "Auth + gestión de usuarios de Krypton. El request 'Login (admin)' guarda el JWT en la variable {{token}} automáticamente; los endpoints de admin lo usan solos.\n\nBase URL por defecto: http://localhost:8080\nAdmin sembrado: admin@krypton.pe / Admin123!",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "adminEmail", "value": "admin@krypton.pe" },
    { "key": "adminPassword", "value": "Admin123!" },
    { "key": "userId", "value": "2" }
  ],
  "item": [
    {
      "name": "Auth (público)",
      "item": [
        {
          "name": "Register (CLIENTE)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Juan Tester\",\n  \"email\": \"juan@test.pe\",\n  \"password\": \"Cliente123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Alta pública. Siempre crea rol CLIENTE. 201 OK, 409 si el email existe, 400 si el body es inválido."
          }
        },
        {
          "name": "Login (admin) → guarda token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('token', res.token);",
                  "  console.log('Token guardado en {{token}}');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Login del admin sembrado. El test script guarda el JWT en {{token}}."
          }
        },
        {
          "name": "Login (cliente) → guarda token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('token', res.token);",
                  "  console.log('Token de cliente guardado en {{token}}');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"juan@test.pe\",\n  \"password\": \"Cliente123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Login del cliente registrado. Útil para probar que un CLIENTE recibe 403 en /api/admin/**."
          }
        }
      ]
    },
    {
      "name": "Admin — Users (requiere token ADMIN)",
      "item": [
        {
          "name": "List users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/users", "host": ["{{baseUrl}}"], "path": ["api", "admin", "users"] },
            "description": "Lista usuarios (sin password). 200 con ADMIN, 403 con CLIENTE, 401 sin token."
          }
        },
        {
          "name": "Create user (rol elegible)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/admin/users", "host": ["{{baseUrl}}"], "path": ["api", "admin", "users"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Otro Admin\",\n  \"email\": \"admin2@krypton.pe\",\n  \"password\": \"Secret123\",\n  \"role\": \"ADMIN\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Crea un usuario con rol elegible (CLIENTE o ADMIN). Único camino para crear un ADMIN."
          }
        },
        {
          "name": "Change role",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/admin/users/{{userId}}/role", "host": ["{{baseUrl}}"], "path": ["api", "admin", "users", "{{userId}}", "role"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"ADMIN\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Cambia el rol del usuario {{userId}}. 422 si intenta degradar al último ADMIN activo."
          }
        },
        {
          "name": "Set status (baja/alta lógica)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/admin/users/{{userId}}/status", "host": ["{{baseUrl}}"], "path": ["api", "admin", "users", "{{userId}}", "status"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"active\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Da de baja (active:false) o reactiva (active:true) al usuario {{userId}}. 422 si desactiva al último ADMIN activo."
          }
        }
      ]
    }
  ]
}
